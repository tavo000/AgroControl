generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum AlertType {
  LOW_FUEL
  HIGH_TEMPERATURE
  HIGH_SPEED
  OFFLINE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InventoryMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum FieldOperationType {
  SOWING
  FERTILIZATION
  SPRAYING
  IRRIGATION
  HARVEST
  SOIL_WORK
  MAINTENANCE
  OTHER
}

enum PlanningTaskStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum PlanningTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users                User[]
  machines             Machine[]
  alerts               Alert[]
  telemetries          Telemetry[]
  farms                Farm[]
  plots                Plot[]
  crops                Crop[]
  harvests             Harvest[]
  campaigns            Campaign[]
  agriculturalCosts    AgriculturalCost[]
  inventoryCategories  InventoryCategory[]
  inventoryItems       InventoryItem[]
  inventoryMovements   InventoryMovement[]
  fieldOperations      FieldOperation[]
  fieldOperationInputs FieldOperationInput[]
  planningTasks        PlanningTask[]
}

model User {
  id       Int @id @default(autoincrement())
  tenantId Int @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  name     String
  email    String @unique
  password String

  role UserRole @default(OPERATOR)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Farm {
  id       Int @id @default(autoincrement())
  tenantId Int @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  name     String
  location String?
  area     Float?
  active   Boolean @default(true)

  plots           Plot[]
  fieldOperations FieldOperation[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  planningTasks PlanningTask[]
}

model Plot {
  id       Int @id @default(autoincrement())
  tenantId Int @default(1)
  farmId   Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  farm   Farm   @relation(fields: [farmId], references: [id])

  name            String
  area            Float?
  crop            String?
  status          String?
  soilType        String?
  lastActivity    String?
  crops           Crop[]
  fieldOperations FieldOperation[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  planningTasks PlanningTask[]
}

model Machine {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name String

  lat Float
  lng Float

  fuel        Float
  temperature Float
  speed       Float

  active Boolean

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  planningTasks PlanningTask[]
}

model Telemetry {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  machineName String

  fuel        Float
  temperature Float
  speed       Float

  lat Float
  lng Float

  active Boolean

  createdAt DateTime @default(now())
}

model Alert {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  machineName String

  type     AlertType
  severity AlertSeverity

  message String

  resolved Boolean @default(false)

  createdAt DateTime @default(now())
}

model Crop {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)
  plotId   Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plot   Plot   @relation(fields: [plotId], references: [id])

  name            String
  variety         String?
  sowingDate      DateTime?
  expectedHarvest DateTime?
  status          String    @default("Activo")

  harvests Harvest[]

  campaignId Int?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Harvest {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)
  cropId   Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  crop   Crop   @relation(fields: [cropId], references: [id])

  harvestDate     DateTime?
  totalProduction Float
  harvestedArea   Float
  yieldPerHectare Float
  unit            String    @default("tn")
  campaign        String?
  observations    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  startDate   DateTime?
  endDate     DateTime?
  description String?
  active      Boolean   @default(true)

  salePricePerTon Float? @default(0)

  crops Crop[]

  costs              AgriculturalCost[]
  inventoryMovements InventoryMovement[]
  fieldOperations    FieldOperation[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  planningTasks PlanningTask[]
}

model AgriculturalCost {
  id Int @id @default(autoincrement())

  tenantId   Int @default(1)
  campaignId Int

  tenant Tenant @relation(fields: [tenantId], references: [id])

  campaign Campaign @relation(fields: [campaignId], references: [id])

  category    String
  description String?

  quantity Float @default(1)

  unitCost Float

  totalCost Float

  costDate DateTime?

  supplier            String?
  inventoryMovementId Int?
  inventoryMovement   InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryCategory {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  description String?
  active      Boolean @default(true)

  items InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryItem {
  id Int @id @default(autoincrement())

  tenantId   Int @default(1)
  categoryId Int

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  category InventoryCategory @relation(fields: [categoryId], references: [id])

  name        String
  description String?
  unit        String  @default("unidad")

  currentStock Float @default(0)
  minimumStock Float @default(0)

  averageCost Float @default(0)

  active Boolean @default(true)

  movements            InventoryMovement[]
  fieldOperationInputs FieldOperationInput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InventoryMovement {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)
  itemId   Int

  tenant Tenant        @relation(fields: [tenantId], references: [id])
  item   InventoryItem @relation(fields: [itemId], references: [id])

  campaignId Int?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  type InventoryMovementType

  quantity  Float
  unitCost  Float @default(0)
  totalCost Float @default(0)

  reason       String?
  supplier     String?
  movementDate DateTime @default(now())

  agriculturalCosts    AgriculturalCost[]
  fieldOperationInputs FieldOperationInput[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FieldOperation {
  id Int @id @default(autoincrement())

  tenantId   Int  @default(1)
  farmId     Int
  plotId     Int
  campaignId Int?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  farm     Farm      @relation(fields: [farmId], references: [id])
  plot     Plot      @relation(fields: [plotId], references: [id])
  campaign Campaign? @relation(fields: [campaignId], references: [id])

  type        FieldOperationType
  title       String
  description String?

  operationDate DateTime @default(now())

  areaWorked Float @default(0)

  laborCost     Float @default(0)
  machineryCost Float @default(0)
  otherCost     Float @default(0)

  totalInputCost     Float @default(0)
  totalOperationCost Float @default(0)

  inputs FieldOperationInput[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  planningTaskId Int?

  planningTask PlanningTask? @relation(fields: [planningTaskId], references: [id])
}

model FieldOperationInput {
  id Int @id @default(autoincrement())

  tenantId            Int  @default(1)
  operationId         Int
  itemId              Int
  inventoryMovementId Int?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  operation         FieldOperation     @relation(fields: [operationId], references: [id])
  item              InventoryItem      @relation(fields: [itemId], references: [id])
  inventoryMovement InventoryMovement? @relation(fields: [inventoryMovementId], references: [id])

  quantity  Float
  unitCost  Float @default(0)
  totalCost Float @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlanningTask {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)

  farmId Int

  plotId Int

  campaignId Int?

  machineId Int?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  farm Farm @relation(fields: [farmId], references: [id])

  plot Plot @relation(fields: [plotId], references: [id])

  campaign Campaign? @relation(fields: [campaignId], references: [id])

  machine Machine? @relation(fields: [machineId], references: [id])

  title String

  description String?

  operationType FieldOperationType

  status PlanningTaskStatus @default(PLANNED)

  priority PlanningTaskPriority @default(MEDIUM)

  plannedDate DateTime

  estimatedArea Float?

  estimatedDuration Float?

  estimatedCost Float?

  assignedOperator String?

  notes String?

  fieldOperations FieldOperation[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}
