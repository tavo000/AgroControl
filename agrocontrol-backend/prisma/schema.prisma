generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  OPERATOR
}

enum AlertType {
  LOW_FUEL
  HIGH_TEMPERATURE
  HIGH_SPEED
  OFFLINE
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Tenant {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  users       User[]
  machines    Machine[]
  alerts      Alert[]
  telemetries Telemetry[]
  farms       Farm[]
  plots       Plot[]
  crops       Crop[]
  harvests    Harvest[]
  campaigns   Campaign[]
  agriculturalCosts AgriculturalCost[]
}

model User {
  id       Int @id @default(autoincrement())
  tenantId Int @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  name     String
  email    String @unique
  password String

  role UserRole @default(OPERATOR)

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Farm {
  id       Int @id @default(autoincrement())
  tenantId Int @default(1)

  tenant Tenant @relation(fields: [tenantId], references: [id])

  name     String
  location String?
  area     Float?
  active   Boolean @default(true)

  plots Plot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plot {
  id       Int @id @default(autoincrement())
  tenantId Int @default(1)
  farmId   Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  farm   Farm   @relation(fields: [farmId], references: [id])

  name         String
  area         Float?
  crop         String?
  status       String?
  soilType     String?
  lastActivity String?
  crops        Crop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Machine {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name String

  lat Float
  lng Float

  fuel        Float
  temperature Float
  speed       Float

  active Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Telemetry {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  machineName String

  fuel        Float
  temperature Float
  speed       Float

  lat Float
  lng Float

  active Boolean

  createdAt DateTime @default(now())
}

model Alert {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  machineName String

  type     AlertType
  severity AlertSeverity

  message String

  resolved Boolean @default(false)

  createdAt DateTime @default(now())
}

model Crop {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)
  plotId   Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  plot   Plot   @relation(fields: [plotId], references: [id])

  name            String
  variety         String?
  sowingDate      DateTime?
  expectedHarvest DateTime?
  status          String    @default("Activo")

  harvests Harvest[]

  campaignId Int?
  campaign   Campaign? @relation(fields: [campaignId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Harvest {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)
  cropId   Int

  tenant Tenant @relation(fields: [tenantId], references: [id])
  crop   Crop   @relation(fields: [cropId], references: [id])

  harvestDate     DateTime?
  totalProduction Float
  harvestedArea   Float
  yieldPerHectare Float
  unit            String    @default("tn")
  campaign        String?
  observations    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Campaign {
  id Int @id @default(autoincrement())

  tenantId Int    @default(1)
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  name        String
  startDate   DateTime?
  endDate     DateTime?
  description String?
  active      Boolean   @default(true)

  salePricePerTon Float? @default(0)

  crops Crop[]

  costs AgriculturalCost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AgriculturalCost {
  id Int @id @default(autoincrement())

  tenantId Int @default(1)
  campaignId Int

  tenant Tenant @relation(fields: [tenantId], references: [id])

  campaign Campaign @relation(fields: [campaignId], references: [id])

  category String
  description String?

  quantity Float @default(1)

  unitCost Float

  totalCost Float

  costDate DateTime?

  supplier String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}